clone "ConversationTemplate" from="JeanSy/building_destroyed" id="Voymastina/building_destroyed" {
    set "Roles" index=1 {
        set "m_SerializedRequirements" index=2 composite="HasOneTag" {
            set "Tags" "voymastina"
        }
    }
    set "Nodes" {
        append "m_SerializedNodes" composite="VARIATION" {
            append "Variations" {
                append "m_SerializedNodes" composite="SAY" {
                    set "Sound" {
                        set "bankId" "tactical_barks_voymastina_va"
                        set "itemId" "Ultimate"
                    }
                    set "RoleGuid" "Killer"
                    set "Text" "Terminator, maximum output."
                }
            }
            append "Variations" {
                append "m_SerializedNodes" composite="SAY" {
                    set "Sound" {
                        set "bankId" "tactical_barks_voymastina_va"
                        set "itemId" "Up4"
                    }
                    set "RoleGuid" "Killer"
                    set "Text" "Dr. Shaw's design, as expected."
                }
            }
        }
        append "m_SerializedNodes" composite="EMPTY" {}
    }
}

