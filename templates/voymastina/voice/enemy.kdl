clone "ConversationTemplate" from="JeanSy/construct_first_sighting_jeansy" id="Voymastina/construct_first_sighting_voymastina" {
    set "Roles" index=1 {
        set "m_SerializedRequirements" index=3 composite="HasOneTag" {
            set "Tags" "voymastina"
        }
    }
    set "Condition" composite="ConversationCondition" {
        set "ExpressionStr" "story_constructs_01_state = 1 & construct_first_sighting_voymastina_played=0"
    }
    set "Nodes" {
        append "m_SerializedNodes" composite="ACTION" {
            set "m_SerAction" composite="SetFlag" {
                set "FlagName" "construct_first_sighting_voymastina_played"
                set "FlagValue" #true
            }
        }
        append "m_SerializedNodes" composite="VARIATION" {
            append "Variations" {
                append "m_SerializedNodes" composite="SAY" {
                    set "Sound" {
                        set "bankId" "tactical_barks_voymastina_va"
                        set "itemId" "BattleStart"
                    }
                    set "RoleGuid" "Explorer"
                    set "Text" "Is that your full strength?"
                }
            }
        }
        append "m_SerializedNodes" composite="EMPTY" {}
    }
}

